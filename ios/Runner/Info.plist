<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>ITSAppUsesNonExemptEncryption</key>
	<false/>
	<!-- Public Google Maps Platform mobile key. Read synchronously by AppDelegate
	     (GMSServices.provideAPIKey) so the Maps SDK is authorized before any map
	     view exists — this is what stops the address-picker map from rendering as
	     a blank grey box. Restrict this key by iOS bundle id + API in Google Cloud;
	     it must be a mobile/web-service key, never a backend-only key. Same value
	     as GOOGLE_MAPS_API_KEY in .vscode/dart_defines.json. -->
	<key>GMSApiKey</key>
	<string>AIzaSyCQiTn7eq3B8jwb4rM8DGJ6WY8uhitNVhI</string>
	<key>CADisableMinimumFrameDurationOnPhone</key>
	<true/>
	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>
	<key>CFBundleDisplayName</key>
	<string>IncaCook</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>IncaCook</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>$(FLUTTER_BUILD_NAME)</string>
	<key>CFBundleSignature</key>
	<string>????</string>
	<key>CFBundleVersion</key>
	<string>$(FLUTTER_BUILD_NUMBER)</string>
	<key>CFBundleURLTypes</key>
	<array>
		<!-- Supabase OAuth callback (incacook://auth/callback) for hosted
		     Facebook sign-in and other Supabase callback flows. -->
		<dict>
			<key>CFBundleURLName</key>
			<string>com.incacook.app.oauth</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>incacook</string>
			</array>
		</dict>
		<!-- Native Google Sign-In callback for the iOS OAuth client ID. -->
		<dict>
			<key>CFBundleURLName</key>
			<string>com.googleusercontent.apps.623882469274-h4uol69lflf0r39n8eg6t9lr2tpnsp6m</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>com.googleusercontent.apps.623882469274-h4uol69lflf0r39n8eg6t9lr2tpnsp6m</string>
			</array>
		</dict>
	</array>
	<!-- Keep custom-scheme callbacks out of Flutter's Navigator. app_links,
	     supabase_flutter, and PayoutOnboardingService consume incacook://...
	     callbacks out-of-band; auto-routing them makes GetX visit /_unknown. -->
	<key>FlutterDeepLinkingEnabled</key>
	<false/>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<key>NSPhotoLibraryUsageDescription</key>
	<string>IncaCook needs access to your photos so you can attach images to food listings.</string>
	<key>NSCameraUsageDescription</key>
	<string>IncaCook utilise la caméra pour vos photos de plats et pour vérifier votre visage lors de l’inscription.</string>
	<key>NSFaceIDUsageDescription</key>
	<string>IncaCook utilise Face ID pour sécuriser votre connexion.</string>
	<key>NSMicrophoneUsageDescription</key>
	<string>IncaCook needs microphone access for video recordings attached to listings.</string>
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>IncaCook uses your location to show nearby kitchens and track deliveries.</string>
	<key>NSLocationAlwaysAndWhenInUseUsageDescription</key>
	<string>IncaCook tracks delivery driver location in the background to keep customers updated on their order.</string>
	<key>UIApplicationSceneManifest</key>
	<dict>
		<key>UIApplicationSupportsMultipleScenes</key>
		<false/>
		<key>UISceneConfigurations</key>
		<dict>
			<key>UIWindowSceneSessionRoleApplication</key>
			<array>
				<dict>
					<key>UISceneClassName</key>
					<string>UIWindowScene</string>
					<key>UISceneConfigurationName</key>
					<string>flutter</string>
					<key>UISceneDelegateClassName</key>
					<string>$(PRODUCT_MODULE_NAME).SceneDelegate</string>
					<key>UISceneStoryboardFile</key>
					<string>Main</string>
				</dict>
			</array>
		</dict>
	</dict>
	<key>UIApplicationSupportsIndirectInputEvents</key>
	<true/>
	<key>UIBackgroundModes</key>
	<array>
		<string>remote-notification</string>
	</array>
	<key>UILaunchStoryboardName</key>
	<string>LaunchScreen</string>
	<key>UIMainStoryboardFile</key>
	<string>Main</string>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
	</array>
	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
	</array>
</dict>
</plist>
