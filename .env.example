# Mapbox PUBLIC access token (pk.…). Used for maps, directions and search.
#
# SECURITY: mobile apps cannot hide secrets — only ever use a PUBLIC token here
# (starts with "pk."). NEVER put a secret token ("sk.") in the app. Restrict the
# public token by URL/scope in the Mapbox dashboard (Account → Tokens).
#
# This file is a template. Copy real values into a local .env (git-ignored) or
# pass them at build time with --dart-define (see below). Do NOT commit .env.
#
# Run Flutter with the token:
#   flutter run --dart-define=MAPBOX_PUBLIC_TOKEN=pk_your_public_mapbox_token_here
MAPBOX_PUBLIC_TOKEN=pk.eyJ1IjoiZ2hvc3RhdmU3IiwiYSI6ImNtcHZjcDRsODAzazUyeXJhZm16cWl4ZWYifQ.ACMGS4gX27uzBjr0s5z8SA

# Backend API base URL (passed via --dart-define, not loaded from this file).
# Resolution priority: API_BASE_URL > LAN_API_BASE_URL > platform-local default
# (Android emulator http://10.0.2.2:3000, otherwise http://localhost:3000).
#
# Use LAN_API_BASE_URL only when testing on a real phone connected to the same
# Wi-Fi as the backend PC (a real device can't reach 10.0.2.2 or localhost).
# Find your PC IPv4 with `ipconfig` (Windows) and keep the :3000 port.
#
#   flutter run --dart-define=LAN_API_BASE_URL=http://192.168.1.20:3000
#   flutter run --dart-define=API_BASE_URL=https://incacook-api-production.up.railway.app
API_BASE_URL=http://localhost:3000
LAN_API_BASE_URL=http://192.168.100.94:3000

# Supabase — used ONLY for hosted OAuth providers (Facebook). Both values are
# PUBLIC client credentials (the anon/publishable key is meant to ship in
# clients, gated by row-level security). NEVER put the service-role key, JWT
# secret, or Facebook App Secret here. Defaults point at the IncaCook prod
# project, so a plain `flutter run` works; override per-env via --dart-define:
#   flutter run --dart-define=SUPABASE_URL=https://xxxx.supabase.co \
#               --dart-define=SUPABASE_ANON_KEY=eyJhbGci...
# SUPABASE_URL=https://eoxrrofpdtrwjbhywcvz.supabase.co
# SUPABASE_ANON_KEY=eyJhbGci...
